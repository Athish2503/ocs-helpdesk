// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  CUSTOMER
  AGENT
  SUPERVISOR
  SUPPORT_L1
  SUPPORT_L2
  BILLING
  ADMIN
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id             String         @id @default(uuid())
  name           String
  email          String         @unique
  passwordHash   String?
  phoneNumber    String?        @map("phone_number")
  crmCustomerId  String?        @unique @map("crm_customer_id")
  role           Role           @default(CUSTOMER)
  isActive       Boolean        @default(true)
  emailVerified  Boolean        @default(false)
  lastLoginAt    DateTime?      @map("last_login_at")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  refreshTokens  RefreshToken[]
  customerTickets Ticket[]      @relation("CustomerTickets")
  agentTickets    Ticket[]      @relation("AgentTickets")
  messages        TicketMessage[]
  teams          Team[]         @relation("TeamMembers")
  kbArticles     KnowledgeBaseArticle[] @relation("AuthorArticles")
  kbVersions     KnowledgeBaseArticleVersion[] @relation("EditorVersions")

  // Redesign relations
  routingRulesAssignee  RoutingRule[]          @relation("RoutingRuleAssignee")
  routingRulesSecondary RoutingRule[]          @relation("RoutingRuleSecondary")
  customerCredits       CustomerCredits?
  statusHistories       TicketStatusHistory[]

  crmCustomer    CrmCustomer?   @relation("UserCrmCustomer", fields: [crmCustomerId], references: [crmCustomerId], onDelete: SetNull)
  sentInvitations Invitation[]  @relation("SentInvitations")

  @@map("users")
}

/// Persisted refresh tokens — allows server-side revocation / rotation.
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model MagicToken {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String
  name      String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("magic_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String?  @unique
  description String?
  isActive    Boolean  @default(true)
  parentId    String?  @map("parent_id")
  parent      Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryParent")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tickets     Ticket[]
  kbArticles  KnowledgeBaseArticle[]

  @@map("categories")
}

model Ticket {
  id          String         @id @default(uuid())
  title       String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  categoryId  String
  category    Category       @relation(fields: [categoryId], references: [id])
  customerId  String
  customer    User           @relation("CustomerTickets", fields: [customerId], references: [id])
  agentId     String?
  agent       User?          @relation("AgentTickets", fields: [agentId], references: [id])
  teamId      String?
  team        Team?          @relation(fields: [teamId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  messages    TicketMessage[]

  // Redesign fields
  affectedDomain  String?        @map("affected_domain")
  issueCategory   String?        @map("issue_category")
  firstResponseAt DateTime?      @map("first_response_at")
  resolvedAt      DateTime?      @map("resolved_at")
  ttrHours        Float?         @map("ttr_hours")

  // CRM details
  crmCustomerId   String?        @map("crm_customer_id")
  domainId        String?        @map("domain_id")
  subscriptionId  String?        @map("subscription_id")
  serviceId       String?        @map("service_id")
  createdBySecondaryEmail String?        @map("created_by_secondary_email")

  crmCustomer     CrmCustomer?   @relation("CustomerCrmTickets", fields: [crmCustomerId], references: [crmCustomerId], onDelete: SetNull)
  domain          CrmDomain?     @relation(fields: [domainId], references: [crmDomainId], onDelete: SetNull)
  subscription    CrmSubscription? @relation(fields: [subscriptionId], references: [crmSubscriptionId], onDelete: SetNull)
  service         CrmService?    @relation(fields: [serviceId], references: [crmServiceId], onDelete: SetNull)

  attachments        TicketAttachment[]
  statusHistory      TicketStatusHistory[]
  creditTransactions CreditTransaction[]

  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  message   String
  createdAt DateTime @default(now())

  @@map("ticket_messages")
}

model Team {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      User[]        @relation("TeamMembers")
  tickets      Ticket[]
  routingRules RoutingRule[]

  @@map("teams")
}

model KnowledgeBaseArticle {
  id               String   @id @default(uuid())
  title            String
  slug             String   @unique
  content          String
  isPublished      Boolean  @default(false) @map("is_published")
  isInternal       Boolean  @default(false) @map("is_internal")
  authorId         String   @map("author_id")
  author           User     @relation("AuthorArticles", fields: [authorId], references: [id])
  categoryId       String?  @map("category_id")
  category         Category? @relation(fields: [categoryId], references: [id])
  
  // SEO overrides
  metaTitle        String?  @map("meta_title") @db.VarChar(60)
  metaDescription  String?  @map("meta_description") @db.VarChar(160)
  keywords         String?
  canonicalUrl     String?  @map("canonical_url") @db.VarChar(255)
  ogImage          String?  @map("og_image") @db.VarChar(500)

  // Analytics fields
  totalReads       Int      @default(0) @map("total_reads")
  uniqueReads      Int      @default(0) @map("unique_reads")
  lastReadAt       DateTime? @map("last_read_at")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  versions         KnowledgeBaseArticleVersion[]
  sources          KnowledgeBaseSource[]
  reads            KnowledgeBaseArticleRead[]
  attachments      KnowledgeBaseArticleAttachment[]
  tags             Tag[]    @relation("ArticleTags")

  @@map("knowledge_base_articles")
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  articles  KnowledgeBaseArticle[] @relation("ArticleTags")

  @@map("knowledge_tags")
}

model KnowledgeBaseArticleVersion {
  id            String   @id @default(uuid())
  articleId     String   @map("article_id")
  article       KnowledgeBaseArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  versionNumber Int      @map("version_number")
  title         String
  content       String
  changedBy     String   @map("changed_by")
  editor        User     @relation("EditorVersions", fields: [changedBy], references: [id])
  changeSummary String?  @map("change_summary")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("knowledge_versions")
}

model KnowledgeBaseSource {
  id                String   @id @default(uuid())
  articleId         String   @map("article_id")
  article           KnowledgeBaseArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  sourceType        String   @map("source_type") // 'dcr', 'manual', 'import'
  sourceReferenceId String?  @map("source_reference_id") // DCR ID if sourceType is 'dcr'
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("knowledge_sources")
}

model KnowledgeBaseArticleRead {
  id                 String   @id @default(uuid())
  articleId          String   @map("article_id")
  article            KnowledgeBaseArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  sessionFingerprint String   @map("session_fingerprint") @db.VarChar(64)
  ipHash             String   @map("ip_hash") @db.VarChar(64)
  userAgent          String?  @map("user_agent")
  referrer           String?  @map("referrer") @db.VarChar(500)
  utmSource          String?  @map("utm_source") @db.VarChar(100)
  utmMedium          String?  @map("utm_medium") @db.VarChar(100)
  utmCampaign        String?  @map("utm_campaign") @db.VarChar(100)
  readDuration       Int      @default(0) @map("read_duration")
  scrollDepth        Int      @default(0) @map("scroll_depth")
  isUnique           Boolean  @default(true) @map("is_unique")
  readAt             DateTime @default(now()) @map("read_at")

  @@map("knowledge_article_reads")
}

model KnowledgeBaseArticleAccessLog {
  id               String   @id @default(uuid())
  articleId        String?  @map("article_id")
  articleSlug      String?  @map("article_slug") @db.VarChar(255)
  ipAddress        String   @map("ip_address") @db.VarChar(45)
  ipHash           String   @map("ip_hash") @db.VarChar(64)
  userAgent        String?  @map("user_agent")
  requestMethod    String   @default("GET") @map("request_method") @db.VarChar(10)
  requestPath      String?  @map("request_path") @db.VarChar(500)
  queryParams      String?  @map("query_params")
  responseStatus   Int?     @map("response_status")
  responseTimeMs   Int?     @map("response_time_ms")
  isBot            Boolean  @default(false) @map("is_bot")
  isSuspicious     Boolean  @default(false) @map("is_suspicious")
  suspiciousReason String?  @map("suspicious_reason") @db.VarChar(255)
  accessedAt       DateTime @default(now()) @map("accessed_at")

  @@map("knowledge_article_access_log")
}

model KnowledgeBaseRateLimit {
  id             String   @id @default(uuid())
  ipAddress      String   @map("ip_address") @db.VarChar(45)
  endpoint       String   @db.VarChar(100)
  requestCount   Int      @default(1) @map("request_count")
  windowStart    DateTime @default(now()) @map("window_start")
  windowEnd      DateTime? @map("window_end")
  isBlocked      Boolean  @default(false) @map("is_blocked")
  violationCount Int      @default(0) @map("violation_count")
  lastRequestAt  DateTime @default(now()) @updatedAt @map("last_request_at")

  @@unique([ipAddress, endpoint, windowStart], name: "unique_ip_endpoint_window")
  @@map("knowledge_rate_limits")
}

model KnowledgeBaseIPBlacklist {
  id          String   @id @default(uuid())
  ipAddress   String   @map("ip_address") @db.VarChar(45)
  reason      String   @db.VarChar(255)
  blockedBy   String   @default("SYSTEM") @map("blocked_by") @db.VarChar(32)
  isPermanent Boolean  @default(false) @map("is_permanent")
  blockedAt   DateTime @default(now()) @map("blocked_at")
  expiresAt   DateTime? @map("expires_at")
  unblockedAt DateTime? @map("unblocked_at")
  notes       String?

  @@map("knowledge_ip_blacklist")
}

model KnowledgeBaseSecurityEvent {
  id             String   @id @default(uuid())
  eventType      String   @map("event_type") // 'RATE_LIMIT_EXCEEDED', 'SQL_INJECTION_ATTEMPT', etc.
  severity       String   @default("MEDIUM") @db.VarChar(10)
  ipAddress      String   @map("ip_address") @db.VarChar(45)
  userAgent      String?  @map("user_agent")
  requestPath    String?  @map("request_path") @db.VarChar(500)
  requestPayload String?  @map("request_payload")
  description    String?
  isResolved     Boolean  @default(false) @map("is_resolved")
  resolvedBy     String?  @map("resolved_by") @db.VarChar(32)
  resolvedAt     DateTime? @map("resolved_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("knowledge_security_events")
}

model KnowledgeBaseArticleAttachment {
  id               String   @id @default(uuid())
  articleId        String   @map("article_id")
  article          KnowledgeBaseArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  filename         String   @db.VarChar(255)
  originalFilename String   @map("original_filename") @db.VarChar(255)
  filePath         String   @map("file_path") @db.VarChar(500)
  fileSize         Int      @map("file_size")
  mimeType         String   @map("mime_type") @db.VarChar(100)
  width            Int?
  height           Int?
  uploadedBy       String   @map("uploaded_by") @db.VarChar(36)
  isFeatured       Boolean  @default(false) @map("is_featured")
  displayOrder     Int      @default(0) @map("display_order")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("knowledge_article_attachments")
}

model TicketAttachment {
  id        String   @id @default(uuid())
  ticketId  String   @map("ticket_id")
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  filename  String
  filePath  String   @map("file_path")
  mimeType  String   @map("mime_type")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ticket_attachments")
}

model TicketStatusHistory {
  id          String        @id @default(uuid())
  ticketId    String        @map("ticket_id")
  ticket      Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromStatus  TicketStatus? @map("from_status")
  toStatus    TicketStatus  @map("to_status")
  changedById String?       @map("changed_by_id")
  changedBy   User?         @relation(fields: [changedById], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now()) @map("created_at")

  @@map("ticket_status_histories")
}

model RoutingRule {
  id                  String   @id @default(uuid())
  issueCategory       String   @unique @map("issue_category") // e.g. "Billing / Renewals", "Technical Support", "Critical Issues"
  assigneeId          String?  @map("assignee_id")
  teamId              String?  @map("team_id")
  secondaryAssigneeId String?  @map("secondary_assignee_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  assignee          User? @relation("RoutingRuleAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  secondaryAssignee User? @relation("RoutingRuleSecondary", fields: [secondaryAssigneeId], references: [id], onDelete: SetNull)
  team              Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@map("routing_rules")
}

model CustomerCredits {
  id             String   @id @default(uuid())
  customerId     String   @unique @map("customer_id")
  customer       User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  allocatedHours Float    @default(0.0) @map("allocated_hours")
  usedHours      Float    @default(0.0) @map("used_hours")
  remainingHours Float    @default(0.0) @map("remaining_hours")
  billableHours  Float    @default(0.0) @map("billable_hours")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  transactions CreditTransaction[]

  @@map("customer_credits")
}

model CreditTransaction {
  id                String          @id @default(uuid())
  customerCreditsId String          @map("customer_credits_id")
  customerCredits   CustomerCredits @relation(fields: [customerCreditsId], references: [id], onDelete: Cascade)
  ticketId          String?         @map("ticket_id")
  ticket            Ticket?         @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  hours             Float
  type              String          // "ALLOCATION", "USAGE", "BILLABLE_OVERAGE"
  description       String?
  createdAt         DateTime        @default(now()) @map("created_at")

  @@map("credit_transactions")
}

model RolePermission {
  id          String   @id @default(uuid())
  role        Role     @unique
  permissions String[]
  createdAt   DateTime @default(now())   @map("created_at")
  updatedAt   DateTime @updatedAt        @map("updated_at")

  @@map("role_permissions")
}

model CrmCustomer {
  id             String   @id @default(uuid())
  crmCustomerId  String   @unique @map("crm_customer_id")
  companyName    String?  @map("company_name")
  displayName    String   @map("display_name")
  primaryEmail   String   @unique @map("primary_email")
  secondaryEmail String?  @map("secondary_email")
  primaryPhone   String?  @map("primary_phone")
  secondaryPhone String?  @map("secondary_phone")
  customerStatus String   @default("ACTIVE") @map("customer_status")
  crmUpdatedAt   DateTime? @map("crm_updated_at")
  lastSyncedAt   DateTime @default(now()) @map("last_synced_at")

  user           User?    @relation("UserCrmCustomer")
  tickets        Ticket[] @relation("CustomerCrmTickets")
  domains        CrmDomain[]
  services       CrmService[]
  subscriptions  CrmSubscription[]
  invitations    Invitation[]

  @@map("crm_customers")
}

model CrmDomain {
  id            String      @id @default(uuid())
  crmDomainId   String      @unique @map("crm_domain_id")
  domainName    String      @map("domain_name")
  crmCustomerId String      @map("crm_customer_id")
  crmCustomer   CrmCustomer @relation(fields: [crmCustomerId], references: [crmCustomerId], onDelete: Cascade)
  createdAt     DateTime    @default(now()) @map("created_at")
  tickets       Ticket[]

  @@map("crm_domains")
}

model CrmService {
  id            String      @id @default(uuid())
  crmServiceId  String      @unique @map("crm_service_id")
  name          String
  status        String
  crmCustomerId String      @map("crm_customer_id")
  domainName    String?     @map("domain_name")
  crmCustomer   CrmCustomer @relation(fields: [crmCustomerId], references: [crmCustomerId], onDelete: Cascade)
  createdAt     DateTime    @default(now()) @map("created_at")
  tickets       Ticket[]

  @@map("crm_services")
}

model CrmSubscription {
  id                String      @id @default(uuid())
  crmSubscriptionId String      @unique @map("crm_subscription_id")
  planName          String      @map("plan_name")
  status            String
  startDate         DateTime    @map("start_date")
  endDate           DateTime?   @map("end_date")
  crmCustomerId     String      @map("crm_customer_id")
  crmCustomer       CrmCustomer @relation(fields: [crmCustomerId], references: [crmCustomerId], onDelete: Cascade)
  createdAt         DateTime    @default(now()) @map("created_at")
  tickets           Ticket[]

  @@map("crm_subscriptions")
}

model Invitation {
  id                String      @id @default(uuid())
  crmCustomerId     String      @map("crm_customer_id")
  crmCustomer       CrmCustomer @relation(fields: [crmCustomerId], references: [crmCustomerId], onDelete: Cascade)
  email             String
  temporaryPassword String?     @map("temporary_password")
  setupToken        String      @unique @map("setup_token")
  expiresAt         DateTime    @map("expires_at")
  usedAt            DateTime?   @map("used_at")
  sentByAdminId     String?     @map("sent_by_admin_id")
  sentByAdmin       User?       @relation("SentInvitations", fields: [sentByAdminId], references: [id], onDelete: SetNull)
  createdAt         DateTime    @default(now()) @map("created_at")

  @@map("invitations")
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String   // INVITATION_SENT, PASSWORD_SETUP, etc.
  entity     String   // User, CrmCustomer, etc.
  entityId   String   @map("entity_id")
  payload    String?  // JSON string
  actorId    String?  @map("actor_id")
  actorEmail String?  @map("actor_email")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}




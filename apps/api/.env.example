PORT=4000
FRONTEND_URL="http://localhost:3001"
BACKEND_URL="http://localhost:4000"
NODE_ENV=development
DATABASE_URL="postgresql://username@localhost:5432/ocs_helpdesk?schema=public"

# JWT — CHANGE THESE IN PRODUCTION (use: openssl rand -hex 64)
JWT_SECRET="dev_jwt_secret_key_change_me_in_production_use_openssl_rand_hex_64"

# SMTP Configuration (Nodemailer)

# For local dev fallback (Mailtrap/Dev Mode):
# SMTP_HOST="smtp.mailtrap.io"
# SMTP_PORT=2525
# SMTP_USER="your_smtp_user"
# SMTP_PASS="your_smtp_password"
# SMTP_FROM='"OCS Helpdesk" <noreply@ocs-helpdesk.local>'

# For Gmail SMTP / Google App Password:
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER="[EMAIL_ADDRESS]"
SMTP_PASS="app_password"
SMTP_FROM='"OCS Helpdesk" <your-email@gmail.com>'

# CRM Integration Settings (Subsync)
CRM_API_URL="http://localhost:3000"
CRM_API_KEY="crm_apikey_default_123456"
CRM_WEBHOOK_SECRET="crm_whsecret_default_123456"